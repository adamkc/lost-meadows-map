# Heavy datasets — staged copies/zips/rasters bound for Google Drive, never versioned.
staging/
logs/

# Bulk geospatial outputs (the small site/data/*.geojson + manifest.json ARE committed;
# these patterns only catch stray large files dropped elsewhere in the tree).
/*.tif
/*.tiff
/*.zip
/*.gpkg
/manifest.csv
drive_files.json

# Large prediction-overlay intermediates (merged GeoJSON; regenerated by R/10_viz.R,
# converted to vector tiles for the site). Never commit these.
site/data/predictions_*.geojson
site/data/huc10_unanalyzed.geojson
R/_*.R

# R / RStudio
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

# OS cruft
.DS_Store
Thumbs.db
*Zone.Identifier

# Editor / tooling state
.vscode/
.idea/
.claude/
*.tmp
*~
